@page "/Erro/{code?}"
@model WebServicos.Pages.ErroModel
@{
    ViewData["Title"] = "Erro " + Model.Code;
    Layout = "_Layout";
}

<div class="text-center py-5">
    @if (Model.Code == "404")
    {
        <i class="bi bi-search display-1 text-warning"></i>
        <h1 class="display-3 fw-bold mt-3">404</h1>
        <h4 class="text-muted">Página não encontrada</h4>
        <p class="text-muted">A página que está a procurar não existe ou foi movida.</p>
    }
    else if (Model.Code == "403" || Model.Code == "AcessoNegado")
    {
        <i class="bi bi-shield-x display-1 text-danger"></i>
        <h1 class="display-3 fw-bold mt-3">403</h1>
        <h4 class="text-muted">Acesso Negado</h4>
        <p class="text-muted">Não tem permissões para aceder a este recurso.</p>
    }
    else
    {
        <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
        <h1 class="display-3 fw-bold mt-3">Erro</h1>
        <h4 class="text-muted">Ocorreu um erro inesperado</h4>
        <p class="text-muted">Por favor tente novamente mais tarde ou contacte o suporte.</p>
    }

    <div class="mt-4 d-flex justify-content-center gap-3">
        <a asp-page="/Index" class="btn btn-primary px-4">
            <i class="bi bi-house me-2"></i>Ir para o Início
        </a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
    </div>
</div>
