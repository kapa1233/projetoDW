@page "{id:int}"
@model WebServicos.Pages.Pedidos.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Pedido";
}

@if (Model.Pedido == null)
{
    <div class="alert alert-danger">Pedido não encontrado.</div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                        Pedido #@Model.Pedido.Id
                    </h5>
                    <span class="badge bg-primary">@Model.Pedido.Estado.GetDisplayName()</span>
                </div>
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-1">@Model.Pedido.TituloProjeto</h4>
                    <p class="text-muted">@Model.Pedido.Descricao</p>

                    @if (!string.IsNullOrEmpty(Model.Pedido.Observacoes))
                    {
                        <div class="alert alert-light border-start border-primary border-3">
                            <strong>Observações:</strong> @Model.Pedido.Observacoes
                        </div>
                    }

                    <div class="row mt-3">
                        <div class="col-sm-6">
                            <p class="mb-1"><strong>Data do Pedido:</strong> @Model.Pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</p>
                            @if (Model.Pedido.PrazoEstimado.HasValue)
                            {
                                <p class="mb-1"><strong>Prazo Estimado:</strong> @Model.Pedido.PrazoEstimado.Value.ToString("dd/MM/yyyy")</p>
                            }
                        </div>
                        <div class="col-sm-6">
                            @if (Model.Pedido.OrcamentoTotal.HasValue)
                            {
                                <p class="mb-1"><strong>Orçamento Estimado:</strong>
                                    <span class="text-success fw-bold fs-5">
                                        @Model.Pedido.OrcamentoTotal.Value.ToString("C", new System.Globalization.CultureInfo("pt-PT"))
                                    </span>
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Serviços incluídos -->
            <div class="card border-0 shadow-sm">
                <div class="card-header">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-grid me-2"></i>Serviços Incluídos</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        @foreach (var ps in Model.Pedido.PedidoServicos)
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <i class="bi @ps.Servico?.Icone text-primary me-2"></i>
                                        <strong>@ps.Servico?.Nome</strong>
                                        @if (!string.IsNullOrEmpty(ps.Notas))
                                        {
                                            <br /><small class="text-muted ms-4">@ps.Notas</small>
                                        }
                                    </div>
                                    @if (ps.PrecoAcordado.HasValue)
                                    {
                                        <span class="text-primary fw-bold">
                                            @ps.PrecoAcordado.Value.ToString("C", new System.Globalization.CultureInfo("pt-PT"))
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-person me-2"></i>Cliente</h6>
                    <p class="mb-1"><strong>@Model.Pedido.Cliente?.NomeCompleto</strong></p>
                    <p class="text-muted small mb-0">@Model.Pedido.Cliente?.Email</p>
                </div>
            </div>

            @if (User.IsInRole("Administrador"))
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3"><i class="bi bi-gear me-2"></i>Alterar Estado</h6>
                        <form method="post" asp-page-handler="AlterarEstado">
                            <input type="hidden" name="id" value="@Model.Pedido.Id" />
                            <select name="novoEstado" class="form-select mb-2">
                                @foreach (var estado in Enum.GetValues<WebServicos.Models.EstadoPedido>())
                                {
                                    <option value="@((int)estado)"
                                            selected="@(Model.Pedido.Estado == estado)">
                                        @estado.GetDisplayName()
                                    </option>
                                }
                            </select>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-save me-1"></i>Atualizar Estado
                            </button>
                        </form>
                    </div>
                </div>
            }

            <div class="mt-3">
                <a asp-page="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i>Voltar à Lista
                </a>
            </div>
        </div>
    </div>
}
