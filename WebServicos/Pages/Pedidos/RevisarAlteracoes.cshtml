@page "{id:int?}"
@model WebServicos.Pages.Pedidos.RevisarAlteracoesModel
@{
    ViewData["Title"] = "Revisar Alterações";
    bool temAlteracao = Model.Alteracao != null;
}

@if (!temAlteracao)
{
    <!-- Lista todas as alterações pendentes -->
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-md-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Alterações Pendentes de Aprovação</h5>
                            <a asp-page="/Pedidos/Index" class="btn btn-light btn-sm">
                                <i class="bi bi-arrow-left me-1"></i>Voltar
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        @if (Model.AlteracoesPendentes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Pedido</th>
                                            <th>Cliente</th>
                                            <th>Data Proposta</th>
                                            <th>Tipo de Alteração</th>
                                            <th>Ação</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var alt in Model.AlteracoesPendentes)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>#@alt.PedidoId</strong><br>
                                                    <small class="text-muted">@alt.Pedido?.TituloProjeto</small>
                                                </td>
                                                <td>@alt.Pedido?.Cliente?.NomeCompleto</td>
                                                <td>
                                                    <small>@alt.DataPropostas.ToString("dd/MM/yyyy HH:mm")</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info">
                                                        @{
                                                            var tipos = new List<string>();
                                                            if (!string.IsNullOrEmpty(alt.TituloProjetoProposto)) tipos.Add("Título");
                                                            if (!string.IsNullOrEmpty(alt.DescricaoProposta)) tipos.Add("Descrição");
                                                            if (!string.IsNullOrEmpty(alt.ObservacoesProposta)) tipos.Add("Observações");
                                                        }
                                                        @string.Join(", ", tipos)
                                                    </span>
                                                </td>
                                                <td>
                                                    <a asp-page="RevisarAlteracoes" asp-route-id="@alt.Id" 
                                                       class="btn btn-sm btn-warning">
                                                        <i class="bi bi-eye me-1"></i>Revisar
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-success text-center py-5">
                                <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                                <p class="mt-3 mb-0">Não há alterações pendentes de aprovação!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Detalhe da alteração para aprovar/rejeitar -->
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-md-10 mx-auto">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-pencil-square me-2"></i>
                                Revisão de Alterações - Pedido #@Model.Pedido?.Id
                            </h5>
                            <a asp-page="RevisarAlteracoes" class="btn btn-light btn-sm">
                                <i class="bi bi-arrow-left me-1"></i>Voltar
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Informações do Pedido -->
                        <div class="card mb-4 bg-light">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="bi bi-file-earmark me-2"></i>Informações do Pedido</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>Cliente:</strong> @Model.Pedido?.Cliente?.NomeCompleto</p>
                                        <p><strong>Email:</strong> @Model.Pedido?.Cliente?.Email</p>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>Data do Pedido:</strong> @Model.Pedido?.DataPedido.ToString("dd/MM/yyyy")</p>
                                        <p><strong>Estado:</strong> 
                                            <span class="badge" style="background-color: @GetEstadoColor(Model.Pedido?.Estado ?? WebServicos.Models.EstadoPedido.Pendente)">
                                                @Model.Pedido?.Estado.GetDisplayName()
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Comparação: Atual vs Proposto -->
                        <div class="card mb-4">
                            <div class="card-header bg-warning text-dark">
                                <h6 class="mb-0"><i class="bi bi-arrows me-2"></i>Comparação: Atual vs Proposto</h6>
                            </div>
                            <div class="card-body">
                                <!-- Título -->
                                @if (!string.IsNullOrEmpty(Model.Alteracao?.TituloProjetoProposto))
                                {
                                    <div class="mb-4">
                                        <h6 class="fw-semibold">Título do Projeto</h6>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="p-3 bg-danger bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Atual:</small>
                                                    <p class="mb-0">@Model.Pedido?.TituloProjeto</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="p-3 bg-success bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Proposto:</small>
                                                    <p class="mb-0">@Model.Alteracao?.TituloProjetoProposto</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <!-- Descrição -->
                                @if (!string.IsNullOrEmpty(Model.Alteracao?.DescricaoProposta))
                                {
                                    <div class="mb-4">
                                        <h6 class="fw-semibold">Descrição</h6>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="p-3 bg-danger bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Atual:</small>
                                                    <p class="mb-0" style="white-space: pre-wrap;">@Model.Pedido?.Descricao</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="p-3 bg-success bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Proposto:</small>
                                                    <p class="mb-0" style="white-space: pre-wrap;">@Model.Alteracao?.DescricaoProposta</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <!-- Observações -->
                                @if (!string.IsNullOrEmpty(Model.Alteracao?.ObservacoesProposta))
                                {
                                    <div class="mb-4">
                                        <h6 class="fw-semibold">Observações</h6>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="p-3 bg-danger bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Atual:</small>
                                                    <p class="mb-0" style="white-space: pre-wrap;">
                                                        @if (string.IsNullOrEmpty(Model.Pedido?.Observacoes))
                                                        {
                                                            <em>Nenhuma observação</em>
                                                        }
                                                        else
                                                        {
                                                            @Model.Pedido?.Observacoes
                                                        }
                                                    </p>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="p-3 bg-success bg-opacity-10 rounded">
                                                    <small class="text-muted d-block mb-1">Proposto:</small>
                                                    <p class="mb-0" style="white-space: pre-wrap;">@Model.Alteracao?.ObservacoesProposta</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Botões de Decisão -->
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-page="RevisarAlteracoes" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Voltar
                            </a>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="bi bi-x-circle me-1"></i>Rejeitar
                            </button>
                            <form method="post" asp-page-handler="Aprovar" class="d-inline">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle me-1"></i>Aprovar & Aplicar
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal para Rejeição -->
    <div class="modal fade" id="rejectModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Rejeitar Alterações</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="Rejeitar">
                    <div class="modal-body">
                        <p>Indique o motivo da rejeição:</p>
                        <textarea asp-for="MotivoRejeicao" class="form-control" rows="4" 
                                  placeholder="Explique por que estas alterações foram rejeitadas..."></textarea>
                        <span asp-validation-for="MotivoRejeicao" class="text-danger small d-block mt-2"></span>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger">Rejeitar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@functions {
    private string GetEstadoColor(WebServicos.Models.EstadoPedido estado)
    {
        return estado switch
        {
            WebServicos.Models.EstadoPedido.Pendente => "#FFC107",
            WebServicos.Models.EstadoPedido.EmAnalise => "#17A2B8",
            WebServicos.Models.EstadoPedido.Aprovado => "#28A745",
            WebServicos.Models.EstadoPedido.EmDesenvolvimento => "#007BFF",
            WebServicos.Models.EstadoPedido.EmRevisao => "#FD7E14",
            WebServicos.Models.EstadoPedido.Concluido => "#20C997",
            WebServicos.Models.EstadoPedido.Cancelado => "#DC3545",
            _ => "#6C757D"
        };
    }
}
