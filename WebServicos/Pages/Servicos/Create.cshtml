@page
@model WebServicos.Pages.Servicos.CreateModel
@{
    ViewData["Title"] = "Novo Serviço";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Novo Serviço</h4>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

                    <div class="mb-3">
                        <label asp-for="Servico.Nome" class="form-label fw-semibold"></label>
                        <input asp-for="Servico.Nome" class="form-control" placeholder="Ex: Website Institucional" />
                        <span asp-validation-for="Servico.Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Servico.Descricao" class="form-label fw-semibold"></label>
                        <textarea asp-for="Servico.Descricao" class="form-control" rows="4"
                                  placeholder="Descreva o serviço em detalhe..."></textarea>
                        <span asp-validation-for="Servico.Descricao" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Servico.PrecoBase" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="Servico.PrecoBase" class="form-control" type="number"
                                       step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Servico.PrecoBase" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Servico.Icone" class="form-label fw-semibold"></label>
                            <input asp-for="Servico.Icone" class="form-control"
                                   placeholder="Ex: bi-globe" />
                            <span asp-validation-for="Servico.Icone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Servico.Ativo" class="form-check-input" type="checkbox" />
                        <label asp-for="Servico.Ativo" class="form-check-label">Serviço Ativo</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Mostrar summary de validação se existirem erros
        const summary = document.getElementById("validationSummary");
        if (summary && summary.querySelectorAll("li").length > 0)
            summary.classList.remove("d-none");
    </script>
}
