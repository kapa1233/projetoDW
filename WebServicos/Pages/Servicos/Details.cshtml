@page "{id:int}"
@model WebServicos.Pages.Servicos.DetailsModel
@{
    ViewData["Title"] = Model.Servico?.Nome ?? "Detalhes do Serviço";
}

@if (Model.Servico == null)
{
    <div class="alert alert-danger">Serviço não encontrado.</div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <i class="bi @Model.Servico.Icone display-1 text-primary mb-3"></i>
                    <h2 class="fw-bold">@Model.Servico.Nome</h2>
                    <p class="lead text-muted">@Model.Servico.Descricao</p>

                    <div class="d-flex justify-content-center gap-4 my-4">
                        <div>
                            <p class="mb-0 text-muted small">Preço Base</p>
                            <h4 class="text-primary fw-bold">
                                @Model.Servico.PrecoBase.ToString("C", new System.Globalization.CultureInfo("pt-PT"))
                            </h4>
                        </div>
                        <div>
                            <p class="mb-0 text-muted small">Estado</p>
                            <span class="badge @(Model.Servico.Ativo ? "bg-success" : "bg-secondary") fs-6">
                                @(Model.Servico.Ativo ? "Disponível" : "Indisponível")
                            </span>
                        </div>
                        <div>
                            <p class="mb-0 text-muted small">Projetos Realizados</p>
                            <h4 class="fw-bold">@Model.TotalPedidos</h4>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-2 mt-4">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Pedidos/Create" asp-route-servicoId="@Model.Servico.Id"
                               class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-plus-circle me-2"></i>Pedir Este Serviço
                            </a>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sessão para Pedir
                            </a>
                        }
                        <a asp-page="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left me-1"></i>Voltar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
