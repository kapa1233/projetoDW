@page "{id:int}"
@model WebServicos.Pages.Servicos.EditModel
@{
    ViewData["Title"] = "Editar Serviço";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0"><i class="bi bi-pencil me-2"></i>Editar Serviço</h4>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <input type="hidden" asp-for="Servico.Id" />

                    <div class="mb-3">
                        <label asp-for="Servico.Nome" class="form-label fw-semibold"></label>
                        <input asp-for="Servico.Nome" class="form-control" />
                        <span asp-validation-for="Servico.Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Servico.Descricao" class="form-label fw-semibold"></label>
                        <textarea asp-for="Servico.Descricao" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Servico.Descricao" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Servico.PrecoBase" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input asp-for="Servico.PrecoBase" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Servico.PrecoBase" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Servico.Icone" class="form-label fw-semibold"></label>
                            <input asp-for="Servico.Icone" class="form-control" />
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Servico.Ativo" class="form-check-input" type="checkbox" />
                        <label asp-for="Servico.Ativo" class="form-check-label">Serviço Ativo</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i>Guardar Alterações
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
