@page
@model WebServicos.Pages.Servicos.IndexModel
@{
    ViewData["Title"] = "Serviços";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold"><i class="bi bi-grid me-2 text-primary"></i>Serviços</h1>
        <p class="text-muted mb-0">Todos os nossos serviços de desenvolvimento web</p>
    </div>
    @if (User.IsInRole("Administrador"))
    {
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Novo Serviço
        </a>
    }
</div>

<!-- Filtro por pesquisa -->
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="pesquisa" value="@Model.Pesquisa" class="form-control"
               placeholder="Pesquisar serviço..." />
        <button class="btn btn-outline-primary" type="submit">
            <i class="bi bi-search"></i> Pesquisar
        </button>
        @if (!string.IsNullOrEmpty(Model.Pesquisa))
        {
            <a asp-page="Index" class="btn btn-outline-secondary">Limpar</a>
        }
    </div>
</form>

@if (!Model.Servicos.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Nenhum serviço encontrado.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var servico in Model.Servicos)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi @servico.Icone fs-2 text-primary me-3"></i>
                            <div>
                                <h5 class="card-title fw-bold mb-0">@servico.Nome</h5>
                                @if (!servico.Ativo)
                                {
                                    <span class="badge bg-secondary">Inativo</span>
                                }
                            </div>
                        </div>
                        <p class="card-text text-muted">@servico.Descricao</p>
                        <p class="fw-bold text-primary mb-0">
                            A partir de @servico.PrecoBase.ToString("C", new System.Globalization.CultureInfo("pt-PT"))
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 d-flex gap-2 pb-3 px-4">
                        <a asp-page="Details" asp-route-id="@servico.Id" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-eye me-1"></i>Detalhes
                        </a>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-page="Edit" asp-route-id="@servico.Id" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil me-1"></i>Editar
                            </a>
                            <a asp-page="Delete" asp-route-id="@servico.Id" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash me-1"></i>Eliminar
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
