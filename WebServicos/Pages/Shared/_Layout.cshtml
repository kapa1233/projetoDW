<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – WebServicos</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- AOS – Animate On Scroll -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
    <!-- Tailwind utilities -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <!-- Estilos próprios -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Navbar ── -->
    <nav class="navbar navbar-expand-lg navbar-light-clean sticky-top" style="z-index:1030;">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand" asp-page="/Index">
                <div class="d-flex align-items-center justify-content-center rounded-2 flex-shrink-0"
                     style="width:28px;height:28px;background:#2563eb;">
                    <i class="bi bi-globe2 text-white" style="font-size:0.8rem;"></i>
                </div>
                WebServicos
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    style="box-shadow:none;color:#64748b;">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">
                            <i class="bi bi-house-door me-1"></i>Início
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Servicos/Index">
                            <i class="bi bi-grid me-1"></i>Serviços
                        </a>
                    </li>
                    <li class="nav-item">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a class="nav-link" asp-page="/Pedidos/Index" 
                               style="color: #3b82f6; font-weight: 600; padding: 0.5rem 1rem; border-radius: 0.5rem; transition: background-color 0.2s;">
                                <i class="bi bi-briefcase-fill me-1"></i>Meus Serviços
                            </a>
                        }
                        else
                        {
                            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login" data-bs-toggle="tooltip" 
                               title="Faça login para ver seus serviços" style="color: #94a3b8; cursor: pointer; padding: 0.5rem 1rem;">
                                <i class="bi bi-briefcase me-1"></i>Meus Serviços
                            </a>
                        }
                    </li>
                    @if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-gear me-1"></i>Administração
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-page="/Clientes/Index">
                                        <i class="bi bi-people me-2" style="color:#2563eb;"></i>Clientes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-page="/Categorias/Index">
                                        <i class="bi bi-tag me-2" style="color:#7c3aed;"></i>Categorias
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" asp-page="/Servicos/Create">
                                        <i class="bi bi-plus-circle me-2" style="color:#16a34a;"></i>Novo Serviço
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item" href="/swagger" target="_blank">
                                        <i class="bi bi-code-square me-2" style="color:#0891b2;"></i>Documentação API
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Sobre">
                            <i class="bi bi-info-circle me-1"></i>Sobre
                        </a>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2">
                    <partial name="_LoginPartial" />

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="position-relative">
                            <button class="btn-notif btn" id="btnNotificacoes" title="Notificações">
                                <i class="bi bi-bell" style="font-size:0.9rem;"></i>
                                <span id="badgeNotif" class="d-none position-absolute"
                                      style="top:-4px;right:-4px;background:#ef4444;color:#fff;border-radius:50%;width:16px;height:16px;font-size:0.6rem;font-weight:700;display:flex!important;align-items:center;justify-content:center;">
                                    0
                                </span>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ── Toast de notificações ── -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;margin-top:4.5rem;">
        <div id="toastNotif" class="toast border-0" role="alert">
            <div class="d-flex align-items-center p-3 gap-2">
                <div style="color:#2563eb;flex-shrink:0;">
                    <i class="bi bi-bell-fill"></i>
                </div>
                <div id="toastNotifMsg" style="font-size:0.85rem;color:#334155;flex:1;">Notificação</div>
                <button type="button" class="btn-close ms-2" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- ── Conteúdo ── -->
    <main class="container my-5">
        @RenderBody()
    </main>

    <!-- ── Footer ── -->
    <footer class="footer-light mt-auto py-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <div class="d-flex align-items-center gap-2">
                    <div class="d-flex align-items-center justify-content-center rounded-2"
                         style="width:20px;height:20px;background:#2563eb;opacity:0.7;">
                        <i class="bi bi-globe2 text-white" style="font-size:0.6rem;"></i>
                    </div>
                    <span style="color:#94a3b8;">
                        <strong style="color:#64748b;">WebServicos</strong> — IPT, Eng. Informática
                    </span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span style="color:#cbd5e1;">&copy; @DateTime.Now.Year</span>
                    <a asp-page="/Sobre">Sobre o projeto</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <!-- AOS – Animate On Scroll -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>AOS.init({ duration: 650, once: true, offset: 60 });</script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hub/notificacoes")
                .withAutomaticReconnect([0, 1000, 3000, 5000, 10000])
                .build();

            // Listeners dos eventos
            // Evento unificado: chega sempre que uma notificação é criada no servidor
            connection.on("NovaNotificacao", (notif) => {
                try {
                    const titulo = notif?.titulo || 'Nova notificação';
                    const tipo = notif?.tipo || '';
                    const icone = tipo === 'NovoPedido' ? '🆕 ' : (tipo === 'PedidoAlterado' ? '📋 ' : (tipo === 'NovaMensagem' ? '✉️ ' : '🔔 '));
                    mostrarNotificacao(`${icone}${titulo}`);

                    // Se o modal estiver aberto, recarrega a lista para refletir em tempo real
                    const modalEl = document.getElementById('modalNotificacoes');
                    if (modalEl && modalEl.classList.contains('show')) {
                        carregarNotificacoes();
                    }
                } catch (e) {
                    console.error('Erro ao processar NovaNotificacao:', e, notif);
                }
            });
            connection.on("NovoPedido", (titulo, cliente, hora) => {
                console.log("Notificação: Novo pedido", titulo, cliente, hora);
                mostrarNotificacao(`Novo pedido: "${titulo}" de ${cliente} às ${hora}`);
            });

            connection.on("PedidoAtualizado", (titulo, estado, hora) => {
                console.log("Notificação: Pedido atualizado", titulo, estado, hora);
                mostrarNotificacao(`O pedido "${titulo}" foi atualizado para: ${estado} (${hora})`);
            });

            connection.on("MensagemEnviada", (pedidoId, remetente, tipoRemetente, hora) => {
                console.log("Notificação: Mensagem enviada", pedidoId, remetente, tipoRemetente, hora);
                mostrarNotificacao(`Mensagem de ${remetente} (${tipoRemetente}) no pedido #${pedidoId} às ${hora}`);
            });

            // Handler genérico emitido pelo servidor ao criar qualquer notificação
            // Atualmente o servidor envia o evento "NovaMensagem" com o título da notificação
            // quando qualquer notificação é criada (novo pedido, atualização, mensagem, etc.).
            // Ao ouvir este evento, garantimos que a barra de notificações reage a todas as ações.
            connection.on("NovaMensagem", (titulo) => {
                try {
                    console.log("Notificação: NovaMensagem (genérica)", titulo);
                    mostrarNotificacao(titulo);
                    // Opcional: se o modal estiver aberto, recarrega a lista
                    if (document.getElementById("modalNotificacoes")?.classList.contains("show")) {
                        if (typeof carregarNotificacoes === 'function') carregarNotificacoes();
                    }
                } catch (e) {
                    console.error("Erro ao processar NovaMensagem:", e);
                }
            });

            // Listener de reconexão
            connection.onreconnected((connectionId) => {
                console.log("SignalR reconectado. Connection ID:", connectionId);
            });

            connection.onreconnecting((error) => {
                console.log("SignalR a tentar reconectar...", error);
            });

            connection.onclose((error) => {
                console.log("SignalR desconectado", error);
                // Tenta reconectar em 3 segundos
                setTimeout(() => connection.start().catch(err => console.error("Erro ao reconectar:", err)), 3000);
            });

            // Inicia a conexão
            connection.start()
                .then(() => {
                    console.log("SignalR conectado com sucesso. Connection ID:", connection.connectionId);
                })
                .catch(err => {
                    console.error("Erro ao conectar SignalR:", err);
                    // Tenta novamente em 5 segundos
                    setTimeout(() => {
                        console.log("Tentando reconectar...");
                        connection.start().catch(err => console.error("Erro na reconexão:", err));
                    }, 5000);
                });

            function mostrarNotificacao(msg) {
                console.log("Mostrando notificação:", msg);
                const msgElement = document.getElementById("toastNotifMsg");
                if (msgElement) {
                    msgElement.textContent = msg;
                    const toastElement = document.getElementById("toastNotif");
                    if (toastElement) {
                        new bootstrap.Toast(toastElement, { delay: 5000 }).show();
                    }
                }
                const badge = document.getElementById("badgeNotif");
                if (badge) {
                    badge.classList.remove("d-none");
                    badge.style.display = "flex";
                    badge.textContent = parseInt(badge.textContent || "0") + 1;
                }
            }

            document.getElementById("btnNotificacoes")?.addEventListener("click", () => {
                const b = document.getElementById("badgeNotif");
                b.textContent = "0";
                b.classList.add("d-none");
                b.style.display = "none";
                // Abre o modal de notificações
                const modalNotif = new bootstrap.Modal(document.getElementById("modalNotificacoes"));
                modalNotif.show();
                // Carrega as notificações
                carregarNotificacoes();
            });
        </script>
    }

    <!-- ── Modal de Notificações ── -->
    <div class="modal fade" id="modalNotificacoes" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered" style="max-width:500px;">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light">
                    <h5 class="modal-title fw-600">
                        <i class="bi bi-bell-fill me-2" style="color:#2563eb;"></i>Notificações
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0" style="max-height:500px;overflow-y:auto;">
                    <div id="notificacoesLista" class="list-group list-group-flush">
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox" style="font-size:2rem;"></i>
                            <p class="mt-2">Carregando notificações...</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-light">
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnMarcarTudasLidas">
                        <i class="bi bi-check-all me-1"></i>Marcar todas como lidas
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Fechar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Script de Notificações ── -->
    <script>
        async function carregarNotificacoes() {
            try {
                const response = await fetch('/api/notificacoes/recentes?limite=20');
                if (!response.ok) throw new Error('Erro ao carregar notificações');

                const notificacoes = await response.json();
                const lista = document.getElementById('notificacoesLista');

                if (notificacoes.length === 0) {
                    lista.innerHTML = `
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox" style="font-size:2rem;"></i>
                            <p class="mt-2">Sem notificações</p>
                        </div>
                    `;
                    return;
                }

                lista.innerHTML = notificacoes.map(notif => `
                    <a href="#" class="list-group-item list-group-item-action py-3 ${notif.lida ? '' : 'border-start border-3 border-primary'}"
                       onclick="abrirNotificacao(${notif.pedidoId || 'null'}); return false;">
                        <div class="d-flex justify-content-between align-items-start">
                            <div style="flex:1;">
                                <h6 class="mb-1 fw-600" style="color:${notif.lida ? '#94a3b8' : '#1e293b'};">
                                    ${notif.titulo}
                                </h6>
                                <p class="mb-2" style="font-size:0.85rem;color:#64748b;">
                                    ${notif.descricao}
                                </p>
                                <small style="color:#94a3b8;">
                                    ${formatarData(notif.dataHora)}
                                </small>
                            </div>
                            <button class="btn btn-sm btn-ghost ms-2" onclick="eliminarNotificacao(event, ${notif.id})" 
                                    title="Eliminar">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </a>
                `).join('');

                // Marca como lidas após 1 segundo
                setTimeout(() => marcarNotificacoesComoLidas(notificacoes), 1000);
            } catch (error) {
                console.error('Erro ao carregar notificações:', error);
                document.getElementById('notificacoesLista').innerHTML = `
                    <div class="text-center py-4 text-danger">
                        <i class="bi bi-exclamation-triangle" style="font-size:2rem;"></i>
                        <p class="mt-2">Erro ao carregar notificações</p>
                    </div>
                `;
            }
        }

        function formatarData(dataString) {
            const data = new Date(dataString);
            const agora = new Date();
            const diferenca = agora - data;
            const minutos = Math.floor(diferenca / (1000 * 60));
            const horas = Math.floor(diferenca / (1000 * 60 * 60));
            const dias = Math.floor(diferenca / (1000 * 60 * 60 * 24));

            if (minutos < 1) return 'agora';
            if (minutos < 60) return `há ${minutos}m`;
            if (horas < 24) return `há ${horas}h`;
            if (dias < 7) return `há ${dias}d`;

            return data.toLocaleDateString('pt-PT');
        }

        async function marcarNotificacoesComoLidas(notificacoes) {
            const naoLidas = notificacoes.filter(n => !n.lida);
            for (const notif of naoLidas) {
                try {
                    await fetch(`/api/notificacoes/${notif.id}/marcar-lida`, { method: 'POST' });
                } catch (error) {
                    console.error('Erro ao marcar notificação como lida:', error);
                }
            }
        }

        async function eliminarNotificacao(event, id) {
            event.preventDefault();
            if (confirm('Tem a certeza que deseja eliminar esta notificação?')) {
                try {
                    const response = await fetch(`/api/notificacoes/${id}`, { method: 'DELETE' });
                    if (response.ok) {
                        carregarNotificacoes();
                    } else {
                        alert('Erro ao eliminar notificação');
                    }
                } catch (error) {
                    console.error('Erro ao eliminar notificação:', error);
                }
            }
        }

        function abrirNotificacao(pedidoId) {
            if (pedidoId) {
                window.location.href = `/Pedidos/Detalhes/${pedidoId}`;
            }
        }

        document.getElementById("btnMarcarTudasLidas")?.addEventListener("click", async () => {
            try {
                const response = await fetch('/api/notificacoes/marcar-todas-lidas', { method: 'POST' });
                if (response.ok) {
                    carregarNotificacoes();
                }
            } catch (error) {
                console.error('Erro ao marcar todas como lidas:', error);
            }
        });

        // Carrega contagem de notificações não lidas ao carregar a página
        async function atualizarContagemNotificacoes() {
            try {
                const response = await fetch('/api/notificacoes/nao-lidas');
                if (!response.ok) return;

                const contagem = await response.json();
                const badge = document.getElementById('badgeNotif');
                if (badge) {
                    if (contagem > 0) {
                        badge.textContent = contagem;
                        badge.classList.remove('d-none');
                        badge.style.display = 'flex';
                    } else {
                        badge.classList.add('d-none');
                    }
                }
            } catch (error) {
                console.error('Erro ao atualizar contagem de notificações:', error);
            }
        }

        // Atualiza contagem ao carregar
        document.addEventListener('DOMContentLoaded', () => {
            if (document.getElementById('btnNotificacoes')) {
                atualizarContagemNotificacoes();
                // Atualiza a cada 30 segundos
                setInterval(atualizarContagemNotificacoes, 30000);
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
