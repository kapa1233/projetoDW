<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – WebServicos</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- CSS próprio -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Navbar ── -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">
                <i class="bi bi-globe2 me-1"></i> WebServicos
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index"><i class="bi bi-house-door me-1"></i>Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Servicos/Index"><i class="bi bi-grid me-1"></i>Serviços</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Pedidos/Index"><i class="bi bi-file-earmark-text me-1"></i>Pedidos</a>
                        </li>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-gear me-1"></i>Administração
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Clientes/Index"><i class="bi bi-people me-2"></i>Clientes</a></li>
                                <li><a class="dropdown-item" asp-page="/Servicos/Create"><i class="bi bi-plus-circle me-2"></i>Novo Serviço</a></li>
                            </ul>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Sobre"><i class="bi bi-info-circle me-1"></i>Sobre</a>
                    </li>
                </ul>

                <!-- Autenticação -->
                <partial name="_LoginPartial" />

                <!-- Sino de notificações SignalR (apenas autenticados) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="ms-2 position-relative">
                        <button class="btn btn-outline-light btn-sm" id="btnNotificacoes" title="Notificações">
                            <i class="bi bi-bell"></i>
                            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle d-none" id="badgeNotif">0</span>
                        </button>
                    </div>
                }
            </div>
        </div>
    </nav>

    <!-- ── Toast de notificações SignalR ── -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999">
        <div id="toastNotif" class="toast align-items-center text-bg-primary border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastNotifMsg">Notificação</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- ── Conteúdo principal ── -->
    <main class="container my-4">
        @RenderBody()
    </main>

    <!-- ── Footer ── -->
    <footer class="footer mt-auto py-3 bg-dark text-light">
        <div class="container text-center">
            <span>
                &copy; @DateTime.Now.Year <strong>WebServicos</strong> —
                Licenciatura em Eng. Informática, IPT |
                <a class="text-light" asp-page="/Sobre">Sobre o projeto</a>
            </span>
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <!-- JS próprio -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            // ── Conexão ao Hub de Notificações (SignalR) ──
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hub/notificacoes")
                .withAutomaticReconnect()
                .build();

            connection.on("NovoPedido", (titulo, cliente, hora) => {
                mostrarNotificacao(`🆕 Novo pedido: "${titulo}" de ${cliente} às ${hora}`);
            });

            connection.on("PedidoAtualizado", (titulo, estado, hora) => {
                mostrarNotificacao(`📋 O pedido "${titulo}" foi atualizado para: ${estado} (${hora})`);
            });

            connection.start().catch(err => console.error("SignalR:", err));

            function mostrarNotificacao(msg) {
                document.getElementById("toastNotifMsg").textContent = msg;
                const toast = new bootstrap.Toast(document.getElementById("toastNotif"));
                toast.show();

                // Atualizar badge
                const badge = document.getElementById("badgeNotif");
                badge.classList.remove("d-none");
                badge.textContent = parseInt(badge.textContent || "0") + 1;
            }

            // Limpar badge ao clicar
            document.getElementById("btnNotificacoes")?.addEventListener("click", () => {
                const badge = document.getElementById("badgeNotif");
                badge.textContent = "0";
                badge.classList.add("d-none");
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
