@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar Sessão";
}

<div class="row justify-content-center">
    <div class="col-sm-10 col-md-7 col-lg-5 col-xl-4">

        <!-- Cabeçalho -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:52px;height:52px;background:#2563eb;">
                <i class="bi bi-globe2 text-white fs-4"></i>
            </div>
            <h1 class="fw-bold fs-3 mb-1">Bem-vindo de volta</h1>
            <p class="text-muted">Inicia sessão na tua conta WebServicos</p>
        </div>

        <!-- Card de login -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <form id="account" method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold small">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Input.Email" class="form-control border-start-0 ps-0"
                                   autocomplete="username" placeholder="o.teu@email.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Input.Password" class="form-label fw-semibold small mb-0">Password</label>
                            <a asp-page="./ForgotPassword" class="small text-primary text-decoration-none">
                                Esqueceste a password?
                            </a>
                        </div>
                        <div class="input-group mt-1">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Input.Password" class="form-control border-start-0 ps-0"
                                   autocomplete="current-password" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label small text-muted" asp-for="Input.RememberMe">
                                Manter sessão iniciada
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                    </button>
                </form>
            </div>
        </div>

        <!-- Link para registo -->
        <p class="text-center text-muted mt-3 small">
            Ainda não tens conta?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
               class="text-primary fw-semibold text-decoration-none">
                Regista-te aqui
            </a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
