@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar Sessão";
}

<style>
    .auth-card {
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 24px rgba(37,99,235,0.08);
    }
    .auth-icon-wrap {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border-radius: 14px;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .form-control-auth {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 0.7rem 1rem;
        font-size: 0.95rem;
        transition: border-color .2s, box-shadow .2s;
    }
    .form-control-auth:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }
    .btn-auth {
        border-radius: 10px;
        padding: 0.7rem;
        font-weight: 600;
        font-size: 0.95rem;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        border: none;
        letter-spacing: 0.01em;
        transition: opacity .2s, transform .1s;
    }
    .btn-auth:hover { opacity: 0.92; transform: translateY(-1px); }
    .field-label { font-size: 0.82rem; font-weight: 600; color: #475569; margin-bottom: 6px; }
</style>

<div class="row justify-content-center">
    <div class="col-12 col-sm-9 col-md-7 col-lg-5 col-xl-4">

        <div class="text-center mb-4 mt-2">
            <div class="auth-icon-wrap mb-3">
                <i class="bi bi-globe2 text-white" style="font-size:1.4rem;"></i>
            </div>
            <h2 class="fw-bold mb-1" style="color:#0f172a;">Bem-vindo de volta</h2>
            <p class="text-muted mb-0" style="font-size:0.9rem;">Inicia sessão na tua conta</p>
        </div>

        <div class="auth-card bg-white p-4">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small rounded-3 mb-3"></div>

            <form id="account" method="post">
                <div class="mb-3">
                    <div class="field-label">Email</div>
                    <input asp-for="Input.Email" class="form-control form-control-auth w-100"
                           autocomplete="username" placeholder="o.teu@email.com" />
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="field-label mb-0">Password</div>
                        <a asp-page="./ForgotPassword" class="text-decoration-none" style="font-size:0.8rem;color:#2563eb;">
                            Esqueceste a password?
                        </a>
                    </div>
                    <input asp-for="Input.Password" class="form-control form-control-auth w-100 mt-1"
                           autocomplete="current-password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="border-radius:5px;" />
                        <label class="form-check-label" asp-for="Input.RememberMe" style="font-size:0.85rem;color:#64748b;">
                            Manter sessão iniciada
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-auth btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                </button>
            </form>
        </div>

        <p class="text-center mt-3 mb-0" style="font-size:0.875rem;color:#64748b;">
            Ainda não tens conta?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
               class="fw-semibold text-decoration-none" style="color:#2563eb;">
                Regista-te gratuitamente
            </a>
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
