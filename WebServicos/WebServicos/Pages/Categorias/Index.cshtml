@page
@model WebServicos.Pages.Categorias.IndexModel
@{
    ViewData["Title"] = "Categorias de Serviço";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold"><i class="bi bi-tag me-2 text-primary"></i>Categorias</h1>
        <p class="text-muted mb-0">Gestão de categorias de serviços</p>
    </div>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nova Categoria
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Categorias.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Nenhuma categoria encontrada.
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Categoria</th>
                        <th>Descrição</th>
                        <th class="text-center">Serviços</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.Categorias)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:8px;height:8px;border-radius:50%;background:#2563eb;"></div>
                                    <strong>@cat.Nome</strong>
                                </div>
                            </td>
                            <td class="text-muted">@(cat.Descricao ?? "—")</td>
                            <td class="text-center">
                                <span class="badge bg-primary rounded-pill">@cat.Servicos.Count</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-page="Edit" asp-route-id="@cat.Id" class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil me-1"></i>Editar
                                </a>
                                <a asp-page="Delete" asp-route-id="@cat.Id" class="btn btn-outline-danger btn-sm ms-1">
                                    <i class="bi bi-trash me-1"></i>Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
