@page "{id}"
@model WebServicos.Pages.Clientes.DetailsModel
@{
    ViewData["Title"] = "Detalhes do Cliente";
}

@if (Model.Cliente == null)
{
    <div class="alert alert-danger">Cliente não encontrado.</div>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-circle display-1 text-primary"></i>
                    <h4 class="fw-bold mt-3">@Model.Cliente.NomeCompleto</h4>
                    <p class="text-muted">@Model.Cliente.Email</p>
                    <span class="badge @(Model.IsAdmin ? "bg-danger" : "bg-secondary")">
                        @(Model.IsAdmin ? "Administrador" : "Cliente")
                    </span>
                    <hr />
                    <p class="text-muted small mb-0">
                        <i class="bi bi-calendar me-1"></i>
                        Registado em @Model.Cliente.DataRegisto.ToString("dd/MM/yyyy")
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-file-earmark-text me-2"></i>
                        Pedidos (@Model.Pedidos.Count)
                    </h5>
                </div>
                <div class="card-body">
                    @if (!Model.Pedidos.Any())
                    {
                        <p class="text-muted text-center py-3">Este cliente ainda não tem pedidos.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var p in Model.Pedidos)
                            {
                                <a asp-page="/Pedidos/Details" asp-route-id="@p.Id"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>#@p.Id — @p.TituloProjeto</strong><br />
                                        <small class="text-muted">@p.DataPedido.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <span class="badge bg-primary">@p.Estado</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <a asp-page="Index" class="btn btn-outline-secondary mt-3">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
}
