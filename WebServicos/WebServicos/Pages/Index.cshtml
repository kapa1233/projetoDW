@page
@model WebServicos.Pages.IndexModel
@{
    ViewData["Title"] = "Início";
}

<!-- Hero Section -->
<section class="hero-section text-center py-5 mb-5 px-4 px-md-5">
    <div class="py-3 position-relative">

        <div class="d-inline-flex align-items-center gap-2 mb-4 px-3 py-2 rounded-pill"
             style="background:#eff6ff;border:1px solid #bfdbfe;font-size:0.78rem;color:#2563eb;font-weight:600;">
            <i class="bi bi-star-fill" style="font-size:0.65rem;"></i>
            Plataforma de Desenvolvimento Web
        </div>

        <h1 class="fw-bold mb-3"
            style="font-size:clamp(2rem,5vw,3.2rem);letter-spacing:-0.04em;color:#0f172a;line-height:1.1;">
            Websites profissionais<br />
            <span style="background:linear-gradient(135deg,#2563eb,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                que fazem a diferença
            </span>
        </h1>

        <p class="mb-4 mx-auto"
           style="max-width:480px;color:#64748b;font-size:1.05rem;line-height:1.7;">
            Do conceito à publicação — criamos soluções web com qualidade,
            rigor e suporte contínuo.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-page="/Servicos/Index" class="btn btn-primary rounded-3 px-4 py-2">
                <i class="bi bi-grid me-2"></i>Ver Serviços
            </a>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-area="Identity" asp-page="/Account/Register"
                   class="btn btn-outline-secondary rounded-3 px-4 py-2">
                    <i class="bi bi-person-plus me-2"></i>Pedir Orçamento
                </a>
            }
            else
            {
                <a asp-page="/Pedidos/Create"
                   class="btn btn-outline-secondary rounded-3 px-4 py-2">
                    <i class="bi bi-plus-circle me-2"></i>Novo Pedido
                </a>
            }
        </div>
    </div>
</section>

<!-- Estatísticas -->
<div class="row g-3 mb-5">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <span class="stat-icon" style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i></span>
            <div class="stat-value">@Model.TotalPedidosConcluidos</div>
            <div class="stat-label">Projetos Concluídos</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <span class="stat-icon" style="color:#2563eb;"><i class="bi bi-people-fill"></i></span>
            <div class="stat-value">@Model.TotalClientes</div>
            <div class="stat-label">Clientes</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <span class="stat-icon" style="color:#7c3aed;"><i class="bi bi-grid-fill"></i></span>
            <div class="stat-value">@Model.TotalServicos</div>
            <div class="stat-label">Serviços Disponíveis</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <span class="stat-icon" style="color:#d97706;"><i class="bi bi-star-fill"></i></span>
            <div class="stat-value">5★</div>
            <div class="stat-label">Avaliação Média</div>
        </div>
    </div>
</div>

<!-- Serviços em destaque -->
<section class="mb-5">
    <div class="d-flex align-items-end justify-content-between mb-4">
        <div>
            <h2 class="fw-bold mb-1"
                style="font-size:1.5rem;letter-spacing:-0.03em;color:#0f172a;">
                Os Nossos Serviços
            </h2>
            <p class="mb-0" style="color:#94a3b8;font-size:0.875rem;">
                Soluções à medida para cada necessidade
            </p>
        </div>
        <a asp-page="/Servicos/Index"
           class="btn btn-sm btn-outline-secondary rounded-3 d-none d-md-inline-flex align-items-center gap-1">
            Ver todos <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="row g-4">
        @foreach (var servico in Model.ServicosDestaque)
        {
            <div class="col-md-4">
                <div class="card-clean h-100 p-4 d-flex flex-column">
                    <!-- Icon + Nome -->
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                             style="width:44px;height:44px;background:#eff6ff;border:1px solid #bfdbfe;">
                            <i class="bi @servico.Icone" style="font-size:1.25rem;color:#2563eb;"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-semibold" style="color:#0f172a;font-size:0.95rem;">@servico.Nome</h5>
                            <span style="color:#2563eb;font-weight:700;font-size:0.875rem;">
                                A partir de @servico.PrecoBase.ToString("C", new System.Globalization.CultureInfo("pt-PT"))
                            </span>
                        </div>
                    </div>
                    <p style="color:#64748b;font-size:0.875rem;line-height:1.7;flex:1;">@servico.Descricao</p>
                    <a asp-page="/Servicos/Details" asp-route-id="@servico.Id"
                       class="btn btn-outline-primary btn-sm rounded-3 mt-2 align-self-start">
                        Saber Mais <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4 d-md-none">
        <a asp-page="/Servicos/Index" class="btn btn-primary rounded-3 px-4">Ver Todos os Serviços</a>
    </div>
</section>

<!-- Porquê escolher-nos -->
<section class="section-highlight p-4 p-md-5 mb-4">
    <h2 class="text-center fw-bold mb-1"
        style="font-size:1.4rem;letter-spacing:-0.03em;color:#0f172a;">
        Porquê escolher a WebServicos?
    </h2>
    <p class="text-center mb-4" style="color:#94a3b8;font-size:0.875rem;">
        O que nos distingue
    </p>
    <div class="row g-4">
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:50px;height:50px;background:#fefce8;border:1px solid #fde68a;">
                <i class="bi bi-lightning-fill" style="color:#d97706;font-size:1.3rem;"></i>
            </div>
            <h6 class="fw-bold mb-2" style="color:#0f172a;">Entrega Rápida</h6>
            <p style="color:#64748b;font-size:0.85rem;line-height:1.7;max-width:240px;margin:0 auto;">
                Cumprimos prazos. O seu projeto é entregue a tempo e com qualidade garantida.
            </p>
        </div>
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:50px;height:50px;background:#f0fdf4;border:1px solid #bbf7d0;">
                <i class="bi bi-phone-fill" style="color:#16a34a;font-size:1.3rem;"></i>
            </div>
            <h6 class="fw-bold mb-2" style="color:#0f172a;">Design Responsivo</h6>
            <p style="color:#64748b;font-size:0.85rem;line-height:1.7;max-width:240px;margin:0 auto;">
                Todos os websites funcionam perfeitamente em qualquer dispositivo.
            </p>
        </div>
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                 style="width:50px;height:50px;background:#eff6ff;border:1px solid #bfdbfe;">
                <i class="bi bi-shield-check-fill" style="color:#2563eb;font-size:1.3rem;"></i>
            </div>
            <h6 class="fw-bold mb-2" style="color:#0f172a;">Suporte Contínuo</h6>
            <p style="color:#64748b;font-size:0.85rem;line-height:1.7;max-width:240px;margin:0 auto;">
                Estamos sempre disponíveis para ajudar após a entrega do projeto.
            </p>
        </div>
    </div>
</section>
