@page "{id:int}"
@model WebServicos.Pages.Pedidos.ChatModel
@{
    ViewData["Title"] = "Chat - Pedido";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Conversa - Pedido #@Model.Pedido?.Id</h5>
                            <small class="text-white-50">@Model.Pedido?.TituloProjeto</small>
                        </div>
                        <a asp-page="Edit" asp-route-id="@Model.Pedido?.Id" class="btn btn-light btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>Voltar
                        </a>
                    </div>
                </div>

                <!-- Área de Mensagens -->
                <div class="card-body" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;">
                    @if (Model.Mensagens.Any())
                    {
                        @foreach (var msg in Model.Mensagens)
                        {
                            var isFromCurrentUser = msg.RemetenteId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            
                            <div class="mb-3 @(isFromCurrentUser ? "text-end" : "")">
                                <div class="d-inline-block" style="max-width: 70%; background-color: @(isFromCurrentUser ? "#DCE2FF" : "#E2E3E5"); border-radius: 10px; padding: 10px 15px;">
                                    <div class="fw-semibold small" style="color: @(isFromCurrentUser ? "#0C63E4" : "#6C757D")">
                                        @msg.Remetente?.NomeCompleto
                                        @if (User.IsInRole("Administrador") && !isFromCurrentUser)
                                        {
                                            <span class="badge bg-primary">Cliente</span>
                                        }
                                        @if (User.IsInRole("Administrador") && isFromCurrentUser)
                                        {
                                            <span class="badge bg-danger">Admin</span>
                                        }
                                    </div>
                                    <p class="mb-1">@msg.Conteudo</p>
                                    <small class="text-muted">@msg.DataHora.ToString("HH:mm")</small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-chat-left-quote" style="font-size: 2rem;"></i>
                            <p class="mt-3">Nenhuma mensagem ainda. Seja o primeiro a enviar!</p>
                        </div>
                    }
                </div>

                <!-- Formulário de Mensagem -->
                <div class="card-footer bg-white border-top">
                    <form method="post" class="d-flex gap-2">
                        <input type="text" asp-for="NovaMsg" class="form-control" 
                               placeholder="Digite sua mensagem..." maxlength="2000" />
                        <button type="submit" class="btn btn-info">
                            <i class="bi bi-send me-1"></i>Enviar
                        </button>
                    </form>
                    @if (ModelState.ContainsKey("NovaMsg") && !ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-sm mt-2 mb-0">
                            <span asp-validation-for="NovaMsg" class="text-danger"></span>
                        </div>
                    }
                </div>
            </div>

            <!-- Informações do Pedido -->
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Informações do Pedido</h6>
                        </div>
                        <div class="card-body small">
                            <div class="mb-2">
                                <strong>Estado:</strong>
                                <span class="badge" style="background-color: @GetEstadoColor(Model.Pedido.Estado)">
                                    @Model.Pedido?.Estado.GetDisplayName()
                                </span>
                            </div>
                            <div class="mb-2">
                                <strong>Cliente:</strong> @Model.Pedido?.Cliente?.NomeCompleto
                            </div>
                            <div class="mb-2">
                                <strong>Data:</strong> @Model.Pedido?.DataPedido.ToString("dd/MM/yyyy")
                            </div>
                            @if (Model.Pedido?.PrazoEstimado.HasValue == true)
                            {
                                <div class="mb-2">
                                    <strong>Prazo:</strong> @Model.Pedido.PrazoEstimado.Value.ToString("dd/MM/yyyy")
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Ações Rápidas</h6>
                        </div>
                        <div class="card-body">
                            <a asp-page="Edit" asp-route-id="@Model.Pedido?.Id" class="btn btn-sm btn-warning w-100 mb-2">
                                <i class="bi bi-pencil me-1"></i>Editar Pedido
                            </a>
                            <a asp-page="Index" class="btn btn-sm btn-secondary w-100">
                                <i class="bi bi-list me-1"></i>Ver Lista
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetEstadoColor(WebServicos.Models.EstadoPedido estado)
    {
        return estado switch
        {
            WebServicos.Models.EstadoPedido.Pendente => "#FFC107",
            WebServicos.Models.EstadoPedido.EmAnalise => "#17A2B8",
            WebServicos.Models.EstadoPedido.Aprovado => "#28A745",
            WebServicos.Models.EstadoPedido.EmDesenvolvimento => "#007BFF",
            WebServicos.Models.EstadoPedido.EmRevisao => "#FD7E14",
            WebServicos.Models.EstadoPedido.Concluido => "#20C997",
            WebServicos.Models.EstadoPedido.Cancelado => "#DC3545",
            _ => "#6C757D"
        };
    }
}
