@page "{id:int}"
@model WebServicos.Pages.Pedidos.DeleteModel
@{
    ViewData["Title"] = "Cancelar Pedido";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Cancelar Pedido</h4>
            </div>
            <div class="card-body p-4 text-center">
                <i class="bi bi-x-circle display-3 text-danger mb-3"></i>
                <h5>Tem a certeza que pretende cancelar este pedido?</h5>
                <div class="card bg-light my-3 text-start">
                    <div class="card-body">
                        <p><strong>Projeto:</strong> @Model.Pedido?.TituloProjeto</p>
                        <p class="mb-0"><strong>Data:</strong> @Model.Pedido?.DataPedido.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
                <p class="text-muted small">Esta ação é irreversível. O pedido será eliminado permanentemente.</p>
                <form method="post">
                    <input type="hidden" asp-for="Pedido!.Id" />
                    <div class="d-flex justify-content-center gap-3 mt-3">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Cancelar Pedido
                        </button>
                        <a asp-page="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Voltar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
