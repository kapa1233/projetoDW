@page
@model WebServicos.Pages.Pedidos.IndexModel
@{
    ViewData["Title"] = "Os Meus Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Pedidos</h1>
        <p class="text-muted mb-0">
            @if (User.IsInRole("Administrador"))
            { <span>Todos os pedidos de clientes</span> }
            else
            { <span>Os seus pedidos de serviço</span> }
        </p>
    </div>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Novo Pedido
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Pedidos.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">Nenhum pedido encontrado</h4>
        <a asp-page="Create" class="btn btn-primary mt-3">
            <i class="bi bi-plus-circle me-1"></i>Criar Primeiro Pedido
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Título do Projeto</th>
                    @if (User.IsInRole("Administrador"))
                    {
                        <th>Cliente</th>
                    }
                    <th>Data</th>
                    <th>Estado</th>
                    <th>Serviços</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in Model.Pedidos)
                {
                    <tr>
                        <td><span class="badge bg-light text-dark">#@pedido.Id</span></td>
                        <td><strong>@pedido.TituloProjeto</strong></td>
                        @if (User.IsInRole("Administrador"))
                        {
                            <td>@pedido.Cliente?.NomeCompleto</td>
                        }
                        <td>@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @GetEstadoBadge(pedido.Estado)">
                                @pedido.Estado.GetDisplayName()
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @pedido.PedidoServicos.Count serviço(s)
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-page="Details" asp-route-id="@pedido.Id"
                                   class="btn btn-sm btn-outline-primary" title="Ver detalhes">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (pedido.Estado == WebServicos.Models.EstadoPedido.Pendente || User.IsInRole("Administrador"))
                                {
                                    <a asp-page="Edit" asp-route-id="@pedido.Id"
                                       class="btn btn-sm btn-outline-warning" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                @if (pedido.Estado == WebServicos.Models.EstadoPedido.Pendente)
                                {
                                    <a asp-page="Delete" asp-route-id="@pedido.Id"
                                       class="btn btn-sm btn-outline-danger" title="Cancelar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    string GetEstadoBadge(WebServicos.Models.EstadoPedido estado) => estado switch
    {
        WebServicos.Models.EstadoPedido.Pendente => "bg-warning text-dark",
        WebServicos.Models.EstadoPedido.EmAnalise => "bg-info text-dark",
        WebServicos.Models.EstadoPedido.Aprovado => "bg-primary",
        WebServicos.Models.EstadoPedido.EmDesenvolvimento => "bg-primary",
        WebServicos.Models.EstadoPedido.EmRevisao => "bg-secondary",
        WebServicos.Models.EstadoPedido.Concluido => "bg-success",
        WebServicos.Models.EstadoPedido.Cancelado => "bg-danger",
        _ => "bg-secondary"
    };
}
