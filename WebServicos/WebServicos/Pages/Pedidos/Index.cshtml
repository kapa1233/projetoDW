@page
@model WebServicos.Pages.Pedidos.IndexModel
@{
    ViewData["Title"] = "Pedidos";
}

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1>
            <i class="bi bi-file-earmark-text me-2" style="color:#2563eb;font-size:1.5rem;vertical-align:middle;"></i>Pedidos
        </h1>
        <p class="page-subtitle">
            @if (User.IsInRole("Administrador"))
            { <span>Todos os pedidos de clientes</span> }
            else
            { <span>Os seus pedidos de serviço</span> }
        </p>
    </div>
    <a asp-page="Create" class="btn btn-primary rounded-3 d-flex align-items-center gap-2">
        <i class="bi bi-plus-circle"></i>
        <span class="d-none d-sm-inline">Novo Pedido</span>
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>@TempData["Sucesso"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span>@TempData["Erro"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Pedidos.Any())
{
    <div class="card-clean text-center py-5 px-4">
        <i class="bi bi-inbox" style="font-size:3rem;color:#cbd5e1;display:block;margin-bottom:1rem;"></i>
        <h5 style="color:#94a3b8;font-weight:600;margin-bottom:0.5rem;">Nenhum pedido encontrado</h5>
        <p style="color:#cbd5e1;font-size:0.875rem;margin-bottom:1.25rem;">Crie o seu primeiro pedido para começar.</p>
        <a asp-page="Create" class="btn btn-primary rounded-3">
            <i class="bi bi-plus-circle me-2"></i>Criar Primeiro Pedido
        </a>
    </div>
}
else
{
    <div class="card-clean overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="padding-left:1.5rem;">#</th>
                        <th>Projeto</th>
                        @if (User.IsInRole("Administrador"))
                        {
                            <th>Cliente</th>
                        }
                        <th>Data</th>
                        <th>Estado</th>
                        <th>Serviços</th>
                        <th style="text-align:right;padding-right:1.5rem;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in Model.Pedidos)
                    {
                        <tr>
                            <td style="padding-left:1.5rem;">
                                <span style="font-size:0.75rem;color:#94a3b8;font-weight:600;font-family:monospace;">
                                    #@pedido.Id
                                </span>
                            </td>
                            <td>
                                <span style="font-weight:600;color:#0f172a;font-size:0.875rem;">@pedido.TituloProjeto</span>
                            </td>
                            @if (User.IsInRole("Administrador"))
                            {
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                             style="width:28px;height:28px;background:#eff6ff;border:1px solid #bfdbfe;font-size:0.7rem;font-weight:700;color:#2563eb;">
                                            @(pedido.Cliente?.NomeCompleto?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <span style="color:#64748b;font-size:0.875rem;">@pedido.Cliente?.NomeCompleto</span>
                                    </div>
                                </td>
                            }
                            <td>
                                <span style="color:#94a3b8;font-size:0.8rem;">@pedido.DataPedido.ToString("dd/MM/yyyy")</span>
                            </td>
                            <td>
                                <span class="estado-badge @GetEstadoClass(pedido.Estado)">
                                    <span style="width:5px;height:5px;border-radius:50%;display:inline-block;background:currentColor;"></span>
                                    @pedido.Estado.GetDisplayName()
                                </span>
                            </td>
                            <td>
                                <span style="font-size:0.75rem;color:#2563eb;background:#eff6ff;border:1px solid #bfdbfe;border-radius:9999px;padding:0.2rem 0.65rem;font-weight:600;">
                                    @pedido.PedidoServicos.Count serv.
                                </span>
                            </td>
                            <td style="text-align:right;padding-right:1.5rem;">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-page="Details" asp-route-id="@pedido.Id"
                                       class="btn btn-sm rounded-2 d-flex align-items-center justify-content-center"
                                       style="width:32px;height:32px;background:#eff6ff;border:1px solid #bfdbfe;color:#2563eb;"
                                       title="Ver detalhes">
                                        <i class="bi bi-eye" style="font-size:0.8rem;"></i>
                                    </a>
                                    @if (pedido.Estado == WebServicos.Models.EstadoPedido.Pendente || User.IsInRole("Administrador"))
                                    {
                                        <a asp-page="Edit" asp-route-id="@pedido.Id"
                                           class="btn btn-sm rounded-2 d-flex align-items-center justify-content-center"
                                           style="width:32px;height:32px;background:#fefce8;border:1px solid #fde68a;color:#d97706;"
                                           title="Editar">
                                            <i class="bi bi-pencil" style="font-size:0.8rem;"></i>
                                        </a>
                                    }
                                    @if (pedido.Estado == WebServicos.Models.EstadoPedido.Pendente)
                                    {
                                        <a asp-page="Delete" asp-route-id="@pedido.Id"
                                           class="btn btn-sm rounded-2 d-flex align-items-center justify-content-center"
                                           style="width:32px;height:32px;background:#fef2f2;border:1px solid #fecaca;color:#b91c1c;"
                                           title="Cancelar">
                                            <i class="bi bi-trash" style="font-size:0.8rem;"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@functions {
    string GetEstadoClass(WebServicos.Models.EstadoPedido estado) => estado switch
    {
        WebServicos.Models.EstadoPedido.Pendente          => "badge-pendente",
        WebServicos.Models.EstadoPedido.EmAnalise         => "badge-analise",
        WebServicos.Models.EstadoPedido.Aprovado          => "badge-aprovado",
        WebServicos.Models.EstadoPedido.EmDesenvolvimento => "badge-dev",
        WebServicos.Models.EstadoPedido.EmRevisao         => "badge-revisao",
        WebServicos.Models.EstadoPedido.Concluido         => "badge-concluido",
        WebServicos.Models.EstadoPedido.Cancelado         => "badge-cancelado",
        _                                                 => "badge-analise"
    };
}
