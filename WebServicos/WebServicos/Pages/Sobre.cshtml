@page
@model WebServicos.Pages.SobreModel
@{
    ViewData["Title"] = "Sobre o Projeto";
}

<style>
    .sobre-hero {
        background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
        border-radius: 1rem;
        color: white;
        padding: 3rem 2rem;
    }
    .avatar-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 700;
        flex-shrink: 0;
    }
    .tech-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 2rem;
        font-size: 0.85rem;
        font-weight: 500;
        margin: 4px;
    }
    .cred-card {
        border-radius: .75rem;
        overflow: hidden;
    }
    .cred-card .cred-header {
        padding: .6rem 1rem;
        font-weight: 600;
        font-size: .9rem;
    }
    .cred-card .cred-body {
        padding: .9rem 1rem;
        background: #f8f9fa;
    }
    .cred-field {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .4rem;
    }
    .cred-field:last-child { margin-bottom: 0; }
    .cred-label { color: #6c757d; font-size: .8rem; margin-bottom: 2px; }
    .info-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: .75rem 0;
        border-bottom: 1px solid #f0f0f0;
    }
    .info-row:last-child { border-bottom: none; }
    .info-icon {
        width: 40px;
        height: 40px;
        border-radius: .5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .flow-step {
        text-align: center;
        padding: 1.25rem 1rem;
    }
    .flow-step .step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #0d6efd;
        color: white;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto .75rem;
        font-size: .9rem;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- Hero -->
        <div class="sobre-hero mb-4 text-center">
            <div class="mb-3">
                <span style="font-size:3rem;">🌐</span>
            </div>
            <h1 class="fw-bold mb-2" style="font-size:2rem;">ProjetoDW — Plataforma de Gestão de Serviços Web</h1>
            <p class="mb-0 opacity-75" style="max-width:520px; margin:0 auto;">
                Trabalho prático da unidade curricular de <strong>Desenvolvimento Web</strong> —
                plataforma onde clientes submetem pedidos e o administrador faz a gestão completa.
            </p>
        </div>

        <!-- O que faz a plataforma (fluxo rápido) -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-center">Como funciona?</h5>
                <div class="row g-2 text-center">
                    <div class="col flow-step">
                        <div class="step-num">1</div>
                        <div class="fw-semibold small">Registo</div>
                        <div class="text-muted" style="font-size:.8rem;">Cliente cria conta na plataforma</div>
                    </div>
                    <div class="col d-flex align-items-center justify-content-center text-muted">
                        <i class="bi bi-arrow-right fs-4"></i>
                    </div>
                    <div class="col flow-step">
                        <div class="step-num">2</div>
                        <div class="fw-semibold small">Pedido</div>
                        <div class="text-muted" style="font-size:.8rem;">Submete pedido de serviço web</div>
                    </div>
                    <div class="col d-flex align-items-center justify-content-center text-muted">
                        <i class="bi bi-arrow-right fs-4"></i>
                    </div>
                    <div class="col flow-step">
                        <div class="step-num">3</div>
                        <div class="fw-semibold small">Gestão</div>
                        <div class="text-muted" style="font-size:.8rem;">Admin acompanha e altera estado</div>
                    </div>
                    <div class="col d-flex align-items-center justify-content-center text-muted">
                        <i class="bi bi-arrow-right fs-4"></i>
                    </div>
                    <div class="col flow-step">
                        <div class="step-num">4</div>
                        <div class="fw-semibold small">Chat</div>
                        <div class="text-muted" style="font-size:.8rem;">Comunicação em tempo real</div>
                    </div>
                    <div class="col d-flex align-items-center justify-content-center text-muted">
                        <i class="bi bi-arrow-right fs-4"></i>
                    </div>
                    <div class="col flow-step">
                        <div class="step-num">5</div>
                        <div class="fw-semibold small">Entrega</div>
                        <div class="text-muted" style="font-size:.8rem;">Pedido concluído e faturado</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">

            <!-- Informações Académicas -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-mortarboard text-primary me-2"></i>Ficha Académica
                        </h5>

                        <div class="info-row">
                            <div class="info-icon bg-primary bg-opacity-10">
                                <i class="bi bi-building text-primary"></i>
                            </div>
                            <div>
                                <div class="text-muted" style="font-size:.75rem;">Instituição</div>
                                <div class="fw-semibold small">Instituto Politécnico de Tomar</div>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon bg-success bg-opacity-10">
                                <i class="bi bi-journal-code text-success"></i>
                            </div>
                            <div>
                                <div class="text-muted" style="font-size:.75rem;">Curso</div>
                                <div class="fw-semibold small">Licenciatura em Engenharia Informática</div>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon bg-warning bg-opacity-10">
                                <i class="bi bi-laptop text-warning"></i>
                            </div>
                            <div>
                                <div class="text-muted" style="font-size:.75rem;">Unidade Curricular</div>
                                <div class="fw-semibold small">Desenvolvimento Web</div>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon bg-info bg-opacity-10">
                                <i class="bi bi-calendar3 text-info"></i>
                            </div>
                            <div>
                                <div class="text-muted" style="font-size:.75rem;">Ano / Semestre / Letivo</div>
                                <div class="fw-semibold small">2º Ano · 2º Semestre · 2024/2025</div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Autores -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-people text-success me-2"></i>Autores
                        </h5>

                        <div class="d-flex align-items-center gap-3 p-3 rounded mb-3" style="background:#f0f7ff; border:1px solid #cce0ff;">
                            <div class="avatar-circle" style="background:linear-gradient(135deg,#0d6efd,#6610f2); color:white;">DG</div>
                            <div>
                                <div class="fw-bold">Diogo Godinho</div>
                                <div class="text-muted small">Nº 27220</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 p-3 rounded" style="background:#f0fff4; border:1px solid #b3e6c8;">
                            <div class="avatar-circle" style="background:linear-gradient(135deg,#198754,#20c997); color:white;">KK</div>
                            <div>
                                <div class="fw-bold">Kanstantsin Khomchanka</div>
                                <div class="text-muted small">Nº 27230</div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Credenciais -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">
                    <i class="bi bi-key text-warning me-2"></i>Credenciais de Demonstração
                </h5>
                <p class="text-muted small mb-3">Use estas contas para explorar as funcionalidades da plataforma.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="cred-card border border-danger">
                            <div class="cred-header bg-danger text-white">
                                <i class="bi bi-shield-fill-check me-1"></i> Administrador — acesso total
                            </div>
                            <div class="cred-body">
                                <div class="cred-field">
                                    <div>
                                        <div class="cred-label">Email</div>
                                        <code>admin@webservicos.pt</code>
                                    </div>
                                </div>
                                <div class="cred-field">
                                    <div>
                                        <div class="cred-label">Password</div>
                                        <code>Admin@123</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="cred-card border border-secondary">
                            <div class="cred-header bg-secondary text-white">
                                <i class="bi bi-person-fill me-1"></i> Cliente — submeter pedidos
                            </div>
                            <div class="cred-body">
                                <div class="cred-field">
                                    <div>
                                        <div class="cred-label">Email</div>
                                        <code>cliente@webservicos.pt</code>
                                    </div>
                                </div>
                                <div class="cred-field">
                                    <div>
                                        <div class="cred-label">Password</div>
                                        <code>Cliente@123</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stack tecnológico -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-stack text-info me-2"></i>Stack Tecnológico
                </h5>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="text-muted small fw-semibold text-uppercase mb-2">Backend</div>
                        <span class="tech-badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                            <i class="bi bi-microsoft"></i> ASP.NET Core 8
                        </span>
                        <span class="tech-badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                            <i class="bi bi-database"></i> Entity Framework Core
                        </span>
                        <span class="tech-badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                            <i class="bi bi-broadcast"></i> SignalR
                        </span>
                        <span class="tech-badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                            <i class="bi bi-shield-lock"></i> ASP.NET Identity
                        </span>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small fw-semibold text-uppercase mb-2">Frontend</div>
                        <span class="tech-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                            <i class="bi bi-bootstrap"></i> Bootstrap 5.3
                        </span>
                        <span class="tech-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                            <i class="bi bi-grid-1x2"></i> Bootstrap Icons
                        </span>
                        <span class="tech-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                            <i class="bi bi-filetype-js"></i> jQuery 3.7
                        </span>
                        <span class="tech-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                            <i class="bi bi-palette"></i> Tailwind CSS
                        </span>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small fw-semibold text-uppercase mb-2">Dados & API</div>
                        <span class="tech-badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                            <i class="bi bi-archive"></i> SQLite
                        </span>
                        <span class="tech-badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                            <i class="bi bi-code-slash"></i> REST API (MVC)
                        </span>
                        <span class="tech-badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                            <i class="bi bi-file-earmark-code"></i> Swagger / OpenAPI
                        </span>
                        <span class="tech-badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                            <i class="bi bi-search"></i> LINQ
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-0">

            <!-- GitHub -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#1a1a2e,#16213e); color:white;">
                    <div class="card-body p-4 text-center d-flex flex-column align-items-center justify-content-center">
                        <i class="bi bi-github" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold mt-2 mb-1">Código Fonte no GitHub</h5>
                        <p class="mb-3 opacity-75 small">Repositório com todo o código, histórico de commits e documentação.</p>
                        <a href="https://github.com/diogogodinhowaze/projetodw" target="_blank"
                           class="btn btn-light px-4">
                            <i class="bi bi-github me-2"></i>Ver Repositório
                        </a>
                    </div>
                </div>
            </div>

            <!-- Relatório -->
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100" style="background:linear-gradient(135deg,#0d6efd,#6610f2); color:white;">
                    <div class="card-body p-4 text-center d-flex flex-column align-items-center justify-content-center">
                        <i class="bi bi-file-earmark-text" style="font-size:2.5rem;"></i>
                        <h5 class="fw-bold mt-2 mb-1">Relatório Técnico</h5>
                        <p class="mb-3 opacity-75 small">Documento completo com arquitetura, modelos, API, deployment e todo o projeto.</p>
                        <a href="~/Relatorio_ProjetoDW.html" download="Relatorio_ProjetoDW.html"
                           class="btn btn-light px-4">
                            <i class="bi bi-download me-2"></i>Descarregar Relatório
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>
